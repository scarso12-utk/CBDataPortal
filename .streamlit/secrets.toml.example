# =============================================================================
# SECRETS TEMPLATE
# For Streamlit Community Cloud, paste these values into Advanced settings.
# If running locally, copy this file to .streamlit/secrets.toml.
# Never upload a real secrets.toml file to GitHub.
# =============================================================================

[portal]
password = "CHOOSE_A_SHARED_PORTAL_PASSWORD"

[aws]
access_key_id = "YOUR_AWS_ACCESS_KEY_ID"
secret_access_key = "YOUR_AWS_SECRET_ACCESS_KEY"
region = "us-east-1"
bucket_name = "composite-bridge-data-568788909451-us-east-1-an"
prefix = ""

# Include this only when using temporary AWS credentials.
# session_token = "YOUR_AWS_SESSION_TOKEN"

# Optional overrides if the object names ever change.
# accell_key = "accell.csv"
# deflect_key = "deflect.csv"
# envir_key = "envir.csv"
# logo_key = "logo.png"
